# Copiar a .env y ajustar.  cp .env.example .env

# Profile(s) por defecto: docker compose los lee de aquí, así corrés solo
# `docker compose up -d` sin pasar --profile. Separar con coma para combinar.
#   standalone | cluster | node1 | node2 | node3 | insight | insight-oauth
# Ej single-host con UI:  COMPOSE_PROFILES=cluster,insight
COMPOSE_PROFILES=standalone

# Password de Redis (requirepass + masterauth). Obligatorio.
# Generar: openssl rand -base64 32 | tr -d "=+/" | cut -c1-25
REDIS_PASSWORD=changeme

# IP que cada nodo del cluster anuncia a los demás y a los clientes.
# DEBE ser una IP real del host (NO 127.0.0.1): con bridge network el gossip
# entre nodos no cruza por loopback.
#   single-host  -> IP LAN del host (ej: 10.9.74.22)
#   multi-host   -> IP pública de ESTE server (distinta en cada máquina)
# Verla con: ip -4 route get 1.1.1.1
ANNOUNCE_IP=

# Interfaz donde se publican los puertos. 0.0.0.0 = todas.
BIND_IP=0.0.0.0

# --- solo multi-host ---------------------------------------------------------
# Las 6 IP:puerto reales, para que cluster-init.sh forme el cluster (una vez).
# Ej: NODES="10.0.0.1:7001 10.0.0.2:7002 10.0.0.3:7003 10.0.0.1:7004 10.0.0.2:7005 10.0.0.3:7006"
NODES=

# --- solo RedisInsight + oauth2 ----------------------------------------------
# En modo insight-oauth poné 127.0.0.1 para que la UI no quede expuesta directa.
INSIGHT_BIND=0.0.0.0
OAUTH2_PROXY_CONFIG_FILE=oauth2-proxy-keycloak.cfg
