# Copiar a .env y ajustar.  cp .env.example .env
#
# Uncommented = REQUIRED.  Commented = optional, shows the default.

# ─────────────────────────────────────────────────────────────────────────────
# Modo

# REQUIRED — profile(s) a levantar. docker compose los lee de aquí, así corrés
# solo `docker compose up -d`. Separar con coma para combinar.
#   standalone | cluster | node1 | node2 | node3 | insight | insight-oauth
COMPOSE_PROFILES=standalone

# ─────────────────────────────────────────────────────────────────────────────
# Redis

# REQUIRED — password (requirepass + masterauth).
# Generar: openssl rand -base64 32 | tr -d "=+/" | cut -c1-25
REDIS_PASSWORD=change_me

# REQUIRED para cluster — IP real del host que cada nodo anuncia. NO 127.0.0.1:
# con bridge network el gossip entre nodos no cruza por loopback.
#   single-host  -> IP LAN del host (ej: 10.9.74.22)
#   multi-host   -> IP pública de ESTE server (distinta en cada máquina)
# Verla con: ip -4 route get 1.1.1.1
ANNOUNCE_IP=

# Interfaz donde se publican los puertos. 0.0.0.0 = todas.
#BIND_IP=0.0.0.0

# ─────────────────────────────────────────────────────────────────────────────
# Multi-host (solo si formás el cluster repartido en varios servers)

# Las 6 IP:puerto reales, para que cluster-init.sh forme el cluster (una vez).
#NODES="10.0.0.1:7001 10.0.0.2:7002 10.0.0.3:7003 10.0.0.1:7004 10.0.0.2:7005 10.0.0.3:7006"

# ─────────────────────────────────────────────────────────────────────────────
# Recursos por nodo (estos defaults son para PRUEBAS)

# Tope de RAM del contenedor. Si Redis lo alcanza sin maxmemory, el OOM killer
# mata el contenedor; por eso maxmemory debe ir por debajo de este tope.
#   PROD: dimensionar a (RAM dedicada / nodos por host), con margen.
#NODE_MEM_LIMIT=512m
# Tope de CPU por nodo. Redis ejecuta comandos en 1 hilo; 1-2 alcanza.
#NODE_CPU_LIMIT=1
# maxmemory de Redis = ~75% de NODE_MEM_LIMIT. Deja headroom para el fork de
# BGSAVE/AOF-rewrite, que por copy-on-write puede duplicar el uso de memoria.
#REDIS_MAXMEMORY=384mb
# Al llegar a maxmemory:
#   noeviction   -> rechaza writes (error). Para DATASTORE: no pierde datos.
#   allkeys-lru  -> evicta las claves menos usadas. Para CACHE.
#REDIS_MAXMEMORY_POLICY=noeviction

# ─────────────────────────────────────────────────────────────────────────────
# RedisInsight + oauth2 (solo profiles insight / insight-oauth)

# En modo insight-oauth poné 127.0.0.1 para que la UI no quede expuesta directa.
#INSIGHT_BIND=0.0.0.0
# Archivo de config del oauth2-proxy dentro de oauth2/.
#OAUTH2_PROXY_CONFIG_FILE=oauth2-proxy-keycloak.cfg
